{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}"
            ],
            "outFiles": [
                "${workspaceFolder}/dist/**/*.js"
            ],
            "preLaunchTask": "npm: watch",
            "env": {
                "INKFLOW_DATABASE_URL": "postgres://inkflow:inkflow_dev@localhost:5434/inkflow"
            }
        }
    ]
}