{
    "name": "inkflow-web",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
        "dev:server": "tsx watch server/index.ts",
        "dev:client": "vite",
        "build": "npm run build:client && npm run build:server",
        "build:client": "vite build",
        "build:server": "tsx server/index.ts --build-check || true",
        "start": "node dist-server/index.js",
        "preview": "vite preview"
    },
    "dependencies": {
        "express": "^5.1.0",
        "pg": "^8.20.0",
        "cors": "^2.8.5",
        "compression": "^1.8.0"
    },
    "devDependencies": {
        "@types/express": "^5.0.0",
        "@types/cors": "^2.8.17",
        "@types/compression": "^1.7.5",
        "@types/node": "^20.17.0",
        "@types/pg": "^8.11.0",
        "@types/react": "^19.1.0",
        "@types/react-dom": "^19.1.0",
        "@vitejs/plugin-react": "^4.5.0",
        "autoprefixer": "^10.4.21",
        "concurrently": "^9.1.0",
        "postcss": "^8.5.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-router-dom": "^7.5.0",
        "tailwindcss": "^4.1.0",
        "@tailwindcss/vite": "^4.1.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "vite": "^6.3.0",
        "date-fns": "^4.1.0",
        "lucide-react": "^0.510.0"
    }
}