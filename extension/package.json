{
    "name": "inkflow",
    "displayName": "InkFlow",
    "description": "Real-time, lossless capture of every Copilot Chat mutation into local PostgreSQL",
    "version": "0.1.0",
    "publisher": "inkflow",
    "repository": {
        "type": "git",
        "url": "https://github.com/inkflow/inkflow"
    },
    "license": "MIT",
    "engines": {
        "vscode": "^1.100.0"
    },
    "categories": [
        "Other"
    ],
    "extensionKind": [
        "workspace"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "configuration": {
            "title": "InkFlow",
            "properties": {
                "inkflow.database.host": {
                    "type": "string",
                    "default": "localhost",
                    "scope": "application",
                    "description": "PostgreSQL host"
                },
                "inkflow.database.port": {
                    "type": "integer",
                    "default": 5434,
                    "minimum": 1,
                    "maximum": 65535,
                    "scope": "application",
                    "description": "PostgreSQL port"
                },
                "inkflow.database.name": {
                    "type": "string",
                    "default": "inkflow",
                    "scope": "application",
                    "description": "PostgreSQL database name"
                },
                "inkflow.database.user": {
                    "type": "string",
                    "default": "inkflow",
                    "scope": "application",
                    "description": "PostgreSQL user"
                },
                "inkflow.database.password": {
                    "type": "string",
                    "default": "inkflow_dev",
                    "scope": "application",
                    "description": "PostgreSQL password"
                },
                "inkflow.database.ssl": {
                    "type": "boolean",
                    "default": false,
                    "scope": "application",
                    "description": "Use SSL for PostgreSQL connection"
                },
                "inkflow.identity.userId": {
                    "type": "string",
                    "default": "",
                    "scope": "application",
                    "description": "Unique user identifier sent with every session. Used to distinguish users in a shared InkFlow instance."
                },
                "inkflow.identity.displayName": {
                    "type": "string",
                    "default": "",
                    "scope": "application",
                    "description": "Human-readable display name for this user."
                },
                "inkflow.watcher.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable file watching for chat sessions"
                },
                "inkflow.watcher.debounceMs": {
                    "type": "integer",
                    "default": 300,
                    "minimum": 50,
                    "maximum": 5000,
                    "description": "Debounce interval for file change events in milliseconds"
                },
                "inkflow.watcher.watchVariants": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "stable",
                            "insiders",
                            "exploration",
                            "vscodium"
                        ]
                    },
                    "default": [
                        "stable"
                    ],
                    "description": "VS Code variants to watch"
                },
                "inkflow.watcher.periodicScanSeconds": {
                    "type": "integer",
                    "default": 30,
                    "minimum": 5,
                    "maximum": 300,
                    "description": "Periodic scan interval in seconds"
                },
                "inkflow.ingestion.filterInputState": {
                    "type": "boolean",
                    "default": true,
                    "description": "Filter out inputState keystroke noise events"
                },
                "inkflow.privacy.redactContent": {
                    "type": "boolean",
                    "default": false,
                    "description": "Redact message content before storing"
                },
                "inkflow.retention.maxAgeDays": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "default": null,
                    "minimum": 7,
                    "description": "Maximum age of stored data in days (null = unlimited)"
                },
                "inkflow.export.defaultFormat": {
                    "type": "string",
                    "enum": [
                        "markdown",
                        "html",
                        "json"
                    ],
                    "default": "markdown",
                    "description": "Default export format"
                },
                "inkflow.export.includeMetadata": {
                    "type": "boolean",
                    "default": true,
                    "description": "Include metadata in exports"
                },
                "inkflow.export.includeForks": {
                    "type": "boolean",
                    "default": true,
                    "description": "Include fork history in exports"
                },
                "inkflow.export.includeDeleted": {
                    "type": "boolean",
                    "default": false,
                    "description": "Include soft-deleted messages in exports"
                }
            }
        },
        "commands": [
            {
                "command": "inkflow.showStatus",
                "title": "InkFlow: Show Status"
            },
            {
                "command": "inkflow.reconnect",
                "title": "InkFlow: Reconnect Database"
            },
            {
                "command": "inkflow.scanNow",
                "title": "InkFlow: Scan Now"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run build",
        "build": "node esbuild.js --production",
        "watch": "node esbuild.js --watch",
        "package": "npm run build && vsce package --no-dependencies",
        "lint": "eslint src",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "vitest run --config vitest.e2e.config.ts"
    },
    "devDependencies": {
        "@types/node": "^20.17.0",
        "@types/vscode": "^1.100.0",
        "@vscode/vsce": "^3.9.0",
        "esbuild": "^0.25.0",
        "typescript": "^5.7.0",
        "vitest": "^3.1.0"
    },
    "dependencies": {
        "pg": "^8.20.0",
        "postgres": "^3.4.7"
    }
}